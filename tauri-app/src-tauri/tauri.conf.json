{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-ai-companion",
  "version": "0.1.0",
  "identifier": "com.ai-companion.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
        {
          "label": "main",
          "title": "Desktop AI Companion",
          "width": 400,
          "height": 600,
          "resizable": false,
          "transparent": true,
          "decorations": false,
          "shadow": false,
          "alwaysOnTop": true,
          "skipTaskbar": true,
          "fullscreen": false
        }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
