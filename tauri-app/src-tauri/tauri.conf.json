{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-ai-companion",
  "version": "0.1.6",
  "identifier": "com.ai-companion.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
        {
          "label": "main",
          "title": "Desktop AI Companion",
          "width": 400,
          "height": 600,
          "resizable": false,
          "transparent": true,
          "decorations": false,
          "shadow": false,
          "alwaysOnTop": true,
          "skipTaskbar": true,
          "fullscreen": false
        },
        {
          "label": "chat",
          "title": "Desktop AI Companion Chat",
          "width": 380,
          "height": 500,
          "minWidth": 320,
          "minHeight": 420,
          "resizable": true,
          "transparent": false,
          "decorations": false,
          "shadow": true,
          "alwaysOnTop": true,
          "skipTaskbar": false,
          "visible": false,
          "fullscreen": false
        },
        {
          "label": "settings",
          "title": "Desktop AI Companion Settings",
          "width": 360,
          "height": 760,
          "resizable": false,
          "transparent": false,
          "decorations": false,
          "shadow": true,
          "alwaysOnTop": true,
          "skipTaskbar": false,
          "visible": false,
          "fullscreen": false
        },
        {
          "label": "model",
          "title": "Desktop AI Companion Models",
          "width": 380,
          "height": 760,
          "resizable": false,
          "transparent": false,
          "decorations": false,
          "shadow": true,
          "alwaysOnTop": true,
          "skipTaskbar": false,
          "visible": false,
          "fullscreen": false
        },
        {
          "label": "cleanup",
          "title": "Desktop AI Companion Cleanup",
          "width": 520,
          "height": 760,
          "minWidth": 420,
          "minHeight": 560,
          "resizable": true,
          "transparent": false,
          "decorations": true,
          "shadow": true,
          "alwaysOnTop": true,
          "skipTaskbar": false,
          "visible": false,
          "fullscreen": false
        },
        {
          "label": "pomodoro",
          "title": "Desktop AI Companion Pomodoro",
          "width": 420,
          "height": 520,
          "minWidth": 360,
          "minHeight": 420,
          "resizable": true,
          "transparent": false,
          "decorations": true,
          "shadow": true,
          "alwaysOnTop": true,
          "skipTaskbar": false,
          "visible": false,
          "fullscreen": false
        }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
